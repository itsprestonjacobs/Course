# Rename this file to ".env" and paste your bot token below.
# NEVER share this token or commit it to GitHub. If it leaks, reset it in the
# Discord Developer Portal.

DISCORD_TOKEN=paste-your-bot-token-here

# (Optional) The ID of your test server. Setting this makes slash commands appear
# INSTANTLY while you develop, instead of taking up to an hour to show globally.
# Right-click your server icon in Discord (with Developer Mode on) -> Copy Server ID.
GUILD_ID=

# (Optional) The name of the role that can see and manage tickets, e.g. "Staff".
# Create this role in your server first. Leave blank to default to "Staff".
STAFF_ROLE_NAME=Staff
